{
  "name": "Exfiltration Over C2 Channel",
  "description": "Exfiltrate sensitive data to external infrastructure. Data is COPIED, not deleted. Duration accounts for data discovery, compression, encryption, and staged transfer to avoid detection.",
  "action_type": "node",
  "mitre_attack": {
    "technique_id": "T1041",
    "technique_name": "Exfiltration Over C2 Channel",
    "tactic": "exfiltration",
    "tactic_id": "TA0010",
    "url": "https://attack.mitre.org/techniques/T1041"
  },
  "cost": 300,
  "duration": 16.0,
  "success_probability": 0.55,
  "enabled_by_default": true,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "access_check",
        "operator": "greater_equal",
        "value": "USER"
      },
      {
        "type": "property_check",
        "property": "c2_established",
        "operator": "equals",
        "value": true
      },
      {
        "type": "property_check",
        "property": "data_staged",
        "operator": "equals",
        "value": true
      },
      {
        "type": "property_check",
        "property": "data_exfiltrated",
        "operator": "not_equals",
        "value": true
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_property",
        "property": "data_exfiltrated",
        "value": true
      },
      {
        "type": "increment_counter",
        "counter": "exfiltration_events",
        "increment": 1
      }
    ]
  },
  "detection_probability": {
    "type": "node_property_based",
    "base_probability": 0.2,
    "property_modifiers": [
      {"property": "properties", "nested_property": "ids_deployed", "value": true, "probability_modifier": 0.2},
      {"property": "properties", "nested_property": "monitoring_enabled", "value": true, "probability_modifier": 0.15}
    ]
  },
  "damage_gain": {
    "one_off_damage": 15000.0,
    "one_off_gain": 8000.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  }
}
