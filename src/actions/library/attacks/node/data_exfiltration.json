{
  "name": "Data Exfiltration",
  "description": "Exfiltrate sensitive data to external infrastructure. Data is COPIED, not deleted. Duration accounts for data discovery, compression, encryption, and staged transfer to avoid detection.",
  "action_type": "node",
  "cost": 300,
  "duration": 16.0,
  "success_probability": 0.55,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {"type": "access_check", "operator": "greater_equal", "value": "USER"},
      {"type": "assets_check", "check_type": "count", "operator": "greater_than", "value": 0}
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {"type": "set_property", "property": "data_exfiltrated", "value": true},
      {"type": "increment_counter", "counter": "exfiltration_events", "increment": 1}
    ]
  },
  "detection_probability": {"type": "constant", "value": 0.35},
  "damage_gain": {
    "one_off_damage": 15000.0,
    "one_off_gain": 8000.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  }
}
