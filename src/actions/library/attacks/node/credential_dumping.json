{
  "name": "Credential Dumping (LSASS)",
  "description": "Extract credentials from Windows LSASS memory using tools like Mimikatz, ProcDump, or comsvcs.dll. Captures plaintext passwords, NTLM hashes, and Kerberos tickets.",
  "action_type": "node",
  "mitre_attack": {
    "technique_id": "T1003.001",
    "technique_name": "OS Credential Dumping: LSASS Memory",
    "tactic": "credential-access",
    "tactic_id": "TA0006",
    "url": "https://attack.mitre.org/techniques/T1003/001/"
  },
  "cost": 100,
  "duration": 0.5,
  "success_probability": 0.65,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "software_check",
        "software_key": "os",
        "operator": "in",
        "values": ["Windows Server", "Windows"]
      },
      {
        "type": "access_check",
        "operator": "equals",
        "value": "ADMIN"
      },
      {
        "type": "property_check",
        "property": "credentials_dumped",
        "operator": "not_equals",
        "value": true
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_property",
        "property": "credentials_dumped",
        "value": true
      },
      {
        "type": "set_property",
        "property": "lateral_movement_enabled",
        "value": true
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.55
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 2500.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  },
  "references": [
    "https://attack.mitre.org/techniques/T1003/001/",
    "https://www.crowdstrike.com/global-threat-report/"
  ],
  "notes": "LSASS dumping is heavily monitored by modern EDR. Requires admin privileges. Credential Guard and LSA protection reduce success rate significantly."
}
