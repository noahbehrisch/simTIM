{
  "name": "MySQL Attack",
  "action_type": "link",
  "cost": 200,
  "duration": 2.0,
  "success_probability": 0.7,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "software_check",
        "software_key": "DBMS name",
        "operator": "equals",
        "value": "MySQL"
      },
      {
        "type": "version_check",
        "software_key": "DBMS version",
        "operator": "between",
        "min_value": "8.0.0",
        "max_value": "8.0.28"
      },
      {
        "type": "access_check",
        "operator": "equals",
        "value": "VISIBLE"
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_access",
        "value": "ADMIN"
      },
      {
        "type": "set_property",
        "property": "compromised",
        "value": true
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.4
  },
  "damage_gain": {
    "one_off_damage": 40.0,
    "one_off_gain": 25.0,
    "time_damage": 8.0,
    "time_gain": 4.0
  }
}
