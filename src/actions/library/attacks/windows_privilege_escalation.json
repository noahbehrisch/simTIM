{
  "name": "Windows Privilege Escalation",
  "description": "Exploits Windows system vulnerabilities for local privilege escalation",
  "action_type": "node",
  "cost": 100,
  "duration": 1.0,
  "success_probability": 0.8,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "software_check",
        "software_key": "os",
        "operator": "in", 
        "values": ["Windows Server", "Windows"]
      },
      {
        "type": "access_check",
        "operator": "equals",
        "value": "USER"
      },
      {
        "type": "vulnerability_check",
        "check_type": "count",
        "operator": "greater_than",
        "value": 0
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_access",
        "value": "ADMIN"
      },
      {
        "type": "set_property",
        "property": "compromised",
        "value": true
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.2
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 20.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  }
}
