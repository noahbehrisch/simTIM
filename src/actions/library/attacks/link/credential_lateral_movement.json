{
  "name": "Credential-Based Lateral Movement",
  "description": "Move laterally to adjacent node using harvested credentials via SMB, RDP, WinRM, or SSH. Per TIM paper, this is a LINK action - precondition checks start node, postcondition applies to end node. Duration accounts for stealth and avoiding detection.",
  "action_type": "link",
  "mitre_attack": {
    "technique_id": "T1021",
    "technique_name": "Remote Services",
    "tactic": "lateral-movement",
    "tactic_id": "TA0008",
    "url": "https://attack.mitre.org/techniques/T1021",
    "sub_techniques": ["T1021.001", "T1021.002", "T1021.004", "T1021.006"]
  },
  "cost": 150,
  "duration": 8.0,
  "success_probability": 0.50,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "start_node_access_check",
        "operator": "greater_equal",
        "value": "USER"
      },
      {
        "type": "start_node_property_check",
        "property": "credentials_harvested",
        "operator": "equals",
        "value": true
      },
      {
        "type": "end_node_access_check",
        "operator": "less_than",
        "value": "USER"
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_access",
        "value": "USER"
      },
      {
        "type": "increment_counter",
        "counter": "lateral_moves",
        "increment": 1
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.35
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 60.0,
    "time_damage": 8.0,
    "time_gain": 2.0
  }
}
