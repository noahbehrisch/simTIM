{
  "name": "Remote Desktop Protocol",
  "description": "Move laterally to a connected Windows node via Remote Desktop Protocol. Requires RDP service running on target. Gains ADMIN access on success. Per TIM paper: link action postcondition applies to END node.",
  "action_type": "link",
  "mitre_attack": {
    "technique_id": "T1021.001",
    "technique_name": "Remote Desktop Protocol",
    "tactic": "lateral-movement",
    "tactic_id": "TA0008",
    "url": "https://attack.mitre.org/techniques/T1021/001"
  },
  "cost": 350.0,
  "duration": 1.5,
  "success_probability": 0.65,
  "enabled_by_default": true,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "end_node_property_check",
        "property": "service_rdp",
        "operator": "equals",
        "value": true
      },
      {
        "type": "start_node_access_check",
        "operator": "greater_equal",
        "value": "USER"
      },
      {
        "type": "end_node_access_check",
        "operator": "less_than",
        "value": "USER"
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_access",
        "value": "USER"
      },
      {
        "type": "set_property",
        "property": "compromised",
        "value": true
      }
    ]
  },
  "detection_probability": {
    "type": "node_property_based",
    "base_probability": 0.2,
    "property_modifiers": [
      {"property": "properties", "nested_property": "ids_deployed", "value": true, "probability_modifier": 0.2},
      {"property": "properties", "nested_property": "monitoring_enabled", "value": true, "probability_modifier": 0.15}
    ]
  },
  "damage_gain": {
    "one_off_damage": 500.0,
    "one_off_gain": 600.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  }
}
