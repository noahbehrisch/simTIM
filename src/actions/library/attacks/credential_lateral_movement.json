{
  "name": "Credential-Based Lateral Movement",
  "description": "Move laterally using harvested credentials via SMB, RDP, or SSH",
  "action_type": "node",
  "cost": 120,
  "duration": 1.5,
  "success_probability": 0.75,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "access_check",
        "operator": "greater_equal",
        "value": "USER"
      },
      {
        "type": "exists",
        "variable": "neighbor",
        "domain": {
          "type": "neighbors"
        },
        "formula": {
          "type": "variable_ref",
          "variable": "neighbor",
          "property": "compromised",
          "operator": "equals",
          "value": false
        }
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_access_neighbors",
        "access_value": "USER"
      },
      {
        "type": "increment_counter",
        "counter": "lateral_moves",
        "increment": 1
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.4
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 40.0,
    "time_damage": 5.0,
    "time_gain": 0.0
  }
}
