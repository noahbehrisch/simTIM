{
  "name": "Incident Response",
  "description": "Investigate and remediate a compromised node. Evicts attacker access by resetting credentials, killing malicious processes, and isolating the system. Requires defender ADMIN access and the node must be flagged as compromised.",
  "action_type": "node",
  "d3fend": {
    "technique_id": "D3-CE",
    "technique_name": "Credential Eviction",
    "url": "https://d3fend.mitre.org/technique/d3f:CredentialEviction",
    "related_techniques": ["D3-CCSA"],
    "tactic": "Evict",
    "related_tactics": ["Detect"]
  },
  "cost": 5000,
  "duration": 4.0,
  "success_probability": 0.75,
  "enabled_by_default": true,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "access_check",
        "operator": "equals",
        "value": "ADMIN"
      },
      {
        "type": "property_check",
        "property": "compromised",
        "operator": "equals",
        "value": true
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "reduce_attacker_access",
        "access_value": "VISIBLE"
      },
      {
        "type": "set_property",
        "property": "compromised",
        "value": false
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.0
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 0.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  }
}
