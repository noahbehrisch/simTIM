{
  "name": "Emergency Security Patch",
  "description": "Rapid deployment of critical security patches that can interrupt ongoing attacks",
  "action_type": "node",
  "d3fend": {
    "technique_id": "D3-SU",
    "technique_name": "Software Update",
    "url": "https://d3fend.mitre.org/technique/d3f:SoftwareUpdate",
    "tactic": "Harden"
  },
  "cost": 150,
  "duration": 2.0,
  "success_probability": 0.95,
  "enabled_by_default": true,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "access_check",
        "operator": "equals",
        "value": "ADMIN"
      },
      {
        "type": "time_check",
        "property": "last_patched",
        "operator": "time_since_greater_than",
        "value": 12
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_software",
        "software_key": "version",
        "value": "2025"
      },
      {
        "type": "set_software",
        "software_key": "web_version",
        "value": "2.4.51"
      },
      {
        "type": "set_property",
        "property": "last_patched",
        "value": "@current_time"
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.0
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 0.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  }
}
