{
  "name": "Comprehensive Security Audit",
  "action_type": "node",
  "d3fend": {
    "technique_id": "D3-AI",
    "technique_name": "Asset Inventory",
    "url": "https://d3fend.mitre.org/technique/d3f:AssetInventory",
    "related_techniques": [
      "D3-CI",
      "D3-SWI"
    ],
    "tactic": "Model"
  },
  "cost": 500,
  "duration": 5.0,
  "success_probability": 0.95,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "access_check",
        "operator": "equals",
        "value": "ADMIN"
      },
      {
        "type": "forall",
        "variable": "vuln",
        "domain": {
          "type": "vulnerabilities"
        },
        "formula": {
          "type": "negation",
          "condition": {
            "type": "variable_ref",
            "variable": "vuln",
            "property": "severity",
            "operator": "equals",
            "value": "critical"
          }
        }
      },
      {
        "type": "implication",
        "premise": {
          "type": "network_check",
          "check_type": "neighbor_count",
          "operator": "greater_than",
          "value": 3
        },
        "conclusion": {
          "type": "exists",
          "variable": "neighbor",
          "domain": {
            "type": "neighbors"
          },
          "formula": {
            "type": "variable_ref",
            "variable": "neighbor",
            "property": "compromised",
            "operator": "equals",
            "value": false
          }
        }
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "remove_vulnerability",
        "method": "all"
      },
      {
        "type": "increment_counter",
        "counter": "security_audits",
        "increment": 1
      },
      {
        "type": "set_property",
        "property": "last_audit",
        "value": "current_time"
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.0
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 100.0,
    "time_damage": 0.0,
    "time_gain": 10.0
  }
}
