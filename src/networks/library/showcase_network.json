{
  "name": "Simple Showcase Network",
  "description": "A minimal 3-node network demonstrating attack progression: reconnaissance → exploitation → privilege escalation → lateral movement → data exfiltration",
  "nodes": [
    {
      "id": "web_server",
      "name": "Internet-Facing Web Server",
      "software": {
        "os": "Ubuntu",
        "version": "20.04",
        "services": ["apache", "php", "mysql-client"]
      },
      "vulnerabilities": [
        "CVE-2021-44228",
        "CVE-2022-22965"
      ],
      "assets": [
        "web_application",
        "access_logs",
        "config_files"
      ],
      "properties": {
        "exposed_to_internet": true,
        "critical": false,
        "category": "Web Server",
        "network_segment": "DMZ"
      }
    },
    {
      "id": "app_server",
      "name": "Internal Application Server",
      "software": {
        "os": "Ubuntu", 
        "version": "18.04",
        "services": ["nginx", "nodejs", "redis"]
      },
      "vulnerabilities": [
        "CVE-2020-1472"
      ],
      "assets": [
        "application_data",
        "user_sessions",
        "cached_credentials"
      ],
      "properties": {
        "exposed_to_internet": false,
        "critical": true,
        "category": "Application Server",
        "network_segment": "Internal"
      }
    },
    {
      "id": "database_server",
      "name": "Sensitive Database Server",
      "software": {
        "os": "Ubuntu",
        "version": "20.04", 
        "services": ["mysql", "ssh"]
      },
      "vulnerabilities": [
        "CVE-2023-1234"
      ],
      "assets": [
        "customer_database",
        "financial_records",
        "sensitive_personal_data",
        "encryption_keys"
      ],
      "properties": {
        "exposed_to_internet": false,
        "critical": true,
        "category": "Database Server",
        "network_segment": "Secure Zone",
        "high_value_target": true
      }
    }
  ],
  "links": [
    {
      "node1": "web_server",
      "node2": "app_server",
      "bidirectional": true,
      "properties": {
        "connection_type": "internal_network",
        "bandwidth": 1000,
        "secured": false
      }
    },
    {
      "node1": "app_server", 
      "node2": "database_server",
      "bidirectional": true,
      "properties": {
        "connection_type": "database_connection",
        "bandwidth": 100,
        "secured": true,
        "requires_authentication": true
      }
    }
  ]
}
