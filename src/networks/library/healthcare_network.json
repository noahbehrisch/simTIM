  "attack_scenarios": [
    {
      "name": "Medical Device Compromise via Legacy OS",
      "description": "Attacker exploits Windows 7 vulnerability on CT scanner, pivots to clinical systems",
      "entry_point": "ct_scanner",
      "attack_path": ["ct_scanner", "medical_firewall", "pacs_server", "ehr_server_primary"], 
      "required_vulnerabilities": ["CVE-2017-0144", "CVE-2022-29464"],
      "impact": "PHI_breach"
    },
    {
      "name": "Wireless Medical Device Attack",
      "description": "Compromise wireless infusion pump, lateral movement to patient monitoring",
      "entry_point": "infusion_pump_01",
      "attack_path": ["infusion_pump_01", "patient_monitor", "medical_firewall", "ehr_server_primary"],
      "required_vulnerabilities": ["CVE-2022-26392", "CVE-2023-20076"], 
      "impact": "patient_safety"
    },
    {
      "name": "Privileged User Compromise",
      "description": "Phishing attack on administrative user leads to full system compromise",
      "entry_point": "admin_workstation",
      "attack_path": ["admin_workstation", "ehr_server_primary", "pacs_server", "his_server"],
      "required_vulnerabilities": ["CVE-2023-36874"], 
      "impact": "full_phi_access"
    },
    {
      "name": "Legacy HIS Server Exploit",
      "description": "Direct attack on outdated HIS server through unpatched vulnerabilities",
      "entry_point": "his_server",
      "attack_path": ["his_server", "ehr_server_primary"],
      "required_vulnerabilities": ["CVE-2017-0144", "CVE-2021-31166"],
      "impact": "administrative_data_breach"
    }
  ],
