{
  "name": "Proof of Concept Network",
  "description": "Minimal 2-node network for verifying simulation behavior. One internet-exposed web server and one internal database server.",
  "nodes": [
    {
      "id": "webserver",
      "name": "webserver",
      "x": 200,
      "y": 300,
      "software": {
        "os": "Ubuntu",
        "version": "22.04",
        "web_server": "nginx",
        "web_version": "1.18.0"
      },
      "assets": [
        "web_application"
      ],
      "properties": {
        "exposed_to_internet": true
      }
    },
    {
      "id": "database",
      "name": "database",
      "x": 600,
      "y": 300,
      "software": {
        "os": "Ubuntu",
        "version": "20.04",
        "database": "PostgreSQL",
        "db_version": "13.4"
      },
      "assets": [
        "customer_data",
        "financial_records"
      ],
      "properties": {
        "exposed_to_internet": false
      }
    }
  ],
  "links": [
    {
      "node1": "webserver",
      "node2": "database",
      "link_type": "ethernet",
      "properties": {
        "bandwidth": "1Gbps",
        "encrypted": false
      }
    }
  ]
}
