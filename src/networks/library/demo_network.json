{
  "name": "Custom Network",
  "description": "Custom network with 6 nodes and 6 links",
  "nodes": [
    {
      "id": "webserver",
      "name": "webserver",
      "x": 720,
      "y": 180,
      "software": {
        "os": "Ubuntu Server",
        "version": "20.04",
        "web_server": "Apache",
        "web_version": "2.4.41"
      },
      "assets": [
        "public_website",
        "web_logs"
      ],
      "properties": {
        "exposed_to_internet": true,
        "network_monitoring": false,
        "endpoint_protection": false
      }
    },
    {
      "id": "mailserver",
      "name": "mailserver",
      "x": 720,
      "y": 420,
      "software": {
        "os": "Debian",
        "version": "11",
        "mail_server": "Postfix"
      },
      "assets": [
        "email_database",
        "user_credentials"
      ],
      "properties": {
        "exposed_to_internet": true,
        "network_monitoring": true,
        "endpoint_protection": false
      }
    },
    {
      "id": "workstation_win",
      "name": "workstation_win",
      "x": 540,
      "y": 300,
      "software": {
        "os": "Windows",
        "version": "10 Pro",
        "office": "Microsoft 365"
      },
      "assets": [
        "user_documents",
        "browser_credentials",
        "cached_passwords"
      ],
      "properties": {
        "exposed_to_internet": false,
        "network_monitoring": false,
        "endpoint_protection": true
      }
    },
    {
      "id": "domain_controller",
      "name": "domain_controller",
      "x": 360,
      "y": 300,
      "software": {
        "os": "Windows Server",
        "version": "2019",
        "role": "Active Directory"
      },
      "assets": [
        "domain_credentials",
        "gpo_policies",
        "user_database",
        "kerberos_keys"
      ],
      "properties": {
        "exposed_to_internet": false,
        "network_monitoring": true,
        "endpoint_protection": true
      }
    },
    {
      "id": "database_server",
      "name": "database_server",
      "x": 180,
      "y": 420,
      "software": {
        "os": "Ubuntu Server",
        "version": "22.04",
        "database": "PostgreSQL",
        "db_version": "14.5"
      },
      "assets": [
        "customer_pii",
        "financial_records",
        "transaction_logs",
        "backup_data"
      ],
      "properties": {
        "exposed_to_internet": false,
        "data_amount": 50000,
        "network_monitoring": true,
        "endpoint_protection": true
      }
    },
    {
      "id": "backup_server",
      "name": "backup_server",
      "x": 180,
      "y": 180,
      "software": {
        "os": "Windows Server",
        "version": "2016",
        "backup_software": "Veeam"
      },
      "assets": [
        "backup_archives",
        "encryption_keys",
        "disaster_recovery_data"
      ],
      "properties": {
        "exposed_to_internet": false,
        "network_monitoring": false,
        "endpoint_protection": false
      }
    }
  ],
  "links": [
    {
      "node1": "webserver",
      "node2": "workstation_win",
      "bidirectional": true
    },
    {
      "node1": "mailserver",
      "node2": "workstation_win",
      "bidirectional": true
    },
    {
      "node1": "workstation_win",
      "node2": "domain_controller",
      "bidirectional": true
    },
    {
      "node1": "domain_controller",
      "node2": "database_server",
      "bidirectional": true
    },
    {
      "node1": "domain_controller",
      "node2": "backup_server",
      "bidirectional": true
    },
    {
      "node1": "database_server",
      "node2": "backup_server",
      "bidirectional": true
    }
  ]
}
