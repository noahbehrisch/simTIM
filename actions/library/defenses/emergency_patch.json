{
  "name": "Emergency Security Patch",
  "description": "Rapid deployment of critical security patches that can interrupt ongoing attacks",
  "action_type": "node", 
  "cost": 150,
  "duration": 2.0,
  "success_probability": 0.95,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "access_check",
        "operator": "equals",
        "value": "ADMIN"
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "remove_vulnerability",
        "vulnerability": "CVE-2017-0144"
      },
      {
        "type": "remove_vulnerability", 
        "vulnerability": "CVE-2021-41773"
      },
      {
        "type": "set_property",
        "property": "last_patched",
        "value": "current_time"
      },
      {
        "type": "set_property",
        "property": "security_level",
        "value": "hardened"
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "probability": 0.0
  },
  "damage_gain": {
    "one_off_damage": 0,
    "one_off_gain": 0,
    "time_damage": -100,
    "time_gain": 0
  }
}
