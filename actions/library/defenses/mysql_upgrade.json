{
  "name": "Upgrading MySQL to new version",
  "action_type": "node",
  "cost": 500,
  "duration": 1.0,
  "success_probability": 0.9,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "software_check",
        "software_key": "DBMS name",
        "operator": "equals",
        "value": "MySQL"
      },
      {
        "type": "version_check",
        "software_key": "DBMS version",
        "operator": "less_than",
        "value": "9.0.1"
      },
      {
        "type": "access_check",
        "operator": "equals",
        "value": "ADMIN"
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_software",
        "software_key": "DBMS version",
        "value": "9.0.1"
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.0
  },
  "damage_gain": {
    "one_off_damage": 0.0,
    "one_off_gain": 0.0,
    "time_damage": 0.0,
    "time_gain": 0.0
  }
}
