{
  "name": "Tapestry attack",
  "action_type": "node",
  "cost": 300,
  "duration": 1.5,
  "success_probability": 0.6,
  "precondition": {
    "type": "compound",
    "operator": "AND",
    "conditions": [
      {
        "type": "software_check",
        "software_key": "WebApp framework name",
        "operator": "equals",
        "value": "Apache Tapestry"
      },
      {
        "type": "software_check",
        "software_key": "WebApp framework version",
        "operator": "in",
        "values": ["5.4.5", "5.5.0", "5.6.2", "5.7.0"]
      },
      {
        "type": "access_check",
        "operator": "equals",
        "value": "VISIBLE"
      }
    ]
  },
  "postcondition": {
    "type": "compound",
    "operator": "AND",
    "actions": [
      {
        "type": "set_access",
        "value": "ADMIN"
      },
      {
        "type": "set_property",
        "property": "compromised",
        "value": true
      }
    ]
  },
  "detection_probability": {
    "type": "constant",
    "value": 0.3
  },
  "damage_gain": {
    "one_off_damage": 50.0,
    "one_off_gain": 30.0,
    "time_damage": 10.0,
    "time_gain": 5.0
  }
}
