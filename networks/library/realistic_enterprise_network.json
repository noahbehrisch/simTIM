  "attack_scenarios": [
    {
      "name": "Web Application Compromise",
      "description": "External attacker exploits web server vulnerability to gain DMZ foothold",
      "entry_point": "dmz_web_server",
      "attack_path": ["dmz_web_server", "internal_firewall", "domain_controller_01", "sql_server_01"],
      "required_vulnerabilities": ["CVE-2021-41773", "CVE-2021-42287"]
    },
    {
      "name": "Phishing to Domain Admin", 
      "description": "Email phishing leads to workstation compromise and privilege escalation",
      "entry_point": "workstation_hr_01",
      "attack_path": ["workstation_hr_01", "domain_controller_01", "sql_server_01"],
      "required_vulnerabilities": ["CVE-2023-36874", "CVE-2021-42287"]
    },
    {
      "name": "IT Admin Compromise",
      "description": "Compromise privileged IT admin workstation for direct server access", 
      "entry_point": "workstation_it_admin",
      "attack_path": ["workstation_it_admin", "domain_controller_01", "sql_server_01"],
      "lateral_movement": "rdp_and_admin_credentials"
    }
