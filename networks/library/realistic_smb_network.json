  "attack_scenarios": [
    {
      "name": "WordPress Compromise",
      "description": "Attacker exploits outdated WordPress to gain web server access",
      "entry_point": "web_hosting_server", 
      "attack_path": ["web_hosting_server", "business_server", "nas_storage"],
      "required_vulnerabilities": ["CVE-2023-23752"]
    },
    {
      "name": "Email Phishing Campaign",
      "description": "Phishing email compromises employee workstation, escalates to domain admin",
      "entry_point": "employee_desktop_01",
      "attack_path": ["employee_desktop_01", "business_server", "manager_laptop", "nas_storage"],
      "required_vulnerabilities": ["CVE-2022-30190", "CVE-2021-31207"]
    },
    {
      "name": "IoT Device Pivot",
      "description": "Compromise printer with default credentials, pivot to file server", 
      "entry_point": "office_printer",
      "attack_path": ["office_printer", "business_server", "nas_storage"],
      "technique": "default_credential_attack"
    },
    {
      "name": "Manager Laptop Compromise",
      "description": "Target high-privilege manager laptop for business data access",
      "entry_point": "manager_laptop",
      "attack_path": ["manager_laptop", "business_server", "nas_storage"], 
      "required_vulnerabilities": ["CVE-2023-21823"]
    }
  ],
  "security_weaknesses": [
    {
      "type": "outdated_software",
      "affected_nodes": ["web_hosting_server", "employee_desktop_01", "employee_desktop_02"],
      "risk": "high"
    },
    {
      "type": "missing_endpoint_protection", 
      "affected_nodes": ["employee_desktop_01", "employee_desktop_02"],
      "risk": "high"
    },
    {
      "type": "default_credentials",
      "affected_nodes": ["office_printer"],
      "risk": "medium"
    },
    {
      "type": "mixed_os_versions",
      "affected_nodes": ["business_server", "manager_laptop", "employee_desktop_01"],
      "risk": "medium"
    },
    {
      "type": "insufficient_network_segmentation", 
      "description": "All internal devices on same subnet",
      "risk": "medium"
    }
  ]
